<!DOCTYPE html>
<html lang="ja">
  <!—260331-2031　参考レシピ/出来上がり量/説明ラベル非表示/閲覧モード調整　-->
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🍪 おかしなぺぇじ 🥐</title>
<link rel="icon" href="favicon.ico" id="faviconLink">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;background:#fafafa;color:#1a1a1a}

.app {
  padding: 1.25rem 1.5rem !important;
  max-width: 960px;
  margin: 0 auto;
  display: block !important;
  width: 100%;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
  margin-bottom: 1.5rem;
  width: 100%;
}

input[type=text]{height:36px;padding:0 10px;border:1px solid #ccc;border-radius:8px;background:#fff;color:#1a1a1a;font-size:14px;outline:none}
input[type=text]:focus{border-color:#D4537E}
select{height:36px;padding:0 10px;border:1px solid #ccc;border-radius:8px;background:#fff;color:#1a1a1a;font-size:14px;cursor:pointer}
.btn{height:36px;padding:0 14px;border:1px solid #ccc;border-radius:8px;background:#fff;color:#1a1a1a;font-size:14px;cursor:pointer;white-space:nowrap}
.btn:hover{background:#f0f0f0}
.btn-accent{background:#D4537E;color:#fff;border-color:#D4537E}
.btn-accent:hover{background:#993556}
.btn-sm{height:28px;padding:0 10px;font-size:12px}

.toolbar-right {
  display: flex;
  gap: 6px;
  align-items: center;
  margin-left: auto;
  flex-shrink: 0;
}

.fav-filter {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-size: 14px;
  color: #888;
  cursor: pointer;
  height: 36px;
  padding: 0 10px;
  border: 1px solid #ccc;
  border-radius: 8px;
  background: #fff;
  width: fit-content;
  min-width: 0 !important;
}
.fav-filter:hover{background:#f0f0f0}
.count-bar{font-size:13px;color:#888;margin-bottom:10px}

.grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px;
  justify-content: center;
  width: 100%;
}

.card{background:#fff;border:1px solid #e5e5e5;border-radius:12px;overflow:hidden;cursor:pointer;transition:border-color .15s}
.card:hover{border-color:#aaa}
.card-img{width:100%;height:130px;object-fit:cover;display:block;background:#f5f5f5}
.card-img-placeholder{width:100%;height:130px;display:flex;align-items:center;justify-content:center;font-size:32px;background:#FBEAF0}
.card-body{padding:10px 12px}
.card-top{display:flex;justify-content:space-between;align-items:flex-start;gap:6px;margin-bottom:4px}
.card-title{font-size:14px;font-weight:500;color:#1a1a1a;line-height:1.4;flex:1}
.hearts{display:flex;gap:2px;flex-shrink:0}
.heart-btn,.star-btn{background:none;border:none;cursor:pointer;font-size:18px;padding:0;line-height:1;color:#ccc}
.heart-btn.on{color:#D4537E}
.star-btn.on{color:#BA7517}
.card-desc{font-size:12px;color:#666;margin-bottom:8px;line-height:1.5}
.tags{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:8px}
.tag{font-size:11px;padding:2px 7px;border-radius:999px;font-weight:400;border:none}
.t-cat{background:#FBEAF0;color:#72243E}
.t-ing{background:#FAEEDA;color:#633806}
.t-pub{background:#EAF3DE;color:#27500A}
.t-priv{background:#F1EFE8;color:#5F5E5A}
.card-footer{font-size:11px;color:#aaa}
.empty{text-align:center;padding:3rem;color:#888;font-size:14px}
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:200;align-items:flex-start;justify-content:center;padding:2rem 1rem;overflow-y:auto}
.overlay.open{display:flex}
.modal{background:#fff;border-radius:12px;border:1px solid #e5e5e5;padding:1.5rem;width:100%;max-width:540px;position:relative}
.modal-close{position:absolute;top:12px;right:14px;background:none;border:none;font-size:18px;cursor:pointer;color:#888;line-height:1}
.modal-close:hover{color:#1a1a1a}
.modal h2{font-size:17px;font-weight:500;margin-bottom:1.25rem;padding-right:24px}
.field{margin-bottom:0.9rem}
.field label{display:block;font-size:12px;color:#666;margin-bottom:3px;font-weight:500}
.field input[type=text],.field textarea{width:100%}
.field textarea{resize:vertical;padding:8px 10px;font-size:13px;border:1px solid #ccc;border-radius:8px;background:#fff;color:#1a1a1a;font-family:inherit;line-height:1.6;outline:none}
.field textarea:focus{border-color:#D4537E}
.field-row{display:flex;gap:8px}
.field-row .field{flex:1}
.modal-btns{display:flex;justify-content:space-between;align-items:center;margin-top:1.25rem;gap:8px}
.modal-btns-right{display:flex;gap:8px}
.detail-section{margin-bottom:1rem}
.detail-section h3{font-size:12px;color:#72243E;margin-bottom:6px;font-weight:500;background:#FBEAF0;padding:4px 8px;border-radius:5px}
.detail-section p{font-size:13px;color:#1a1a1a;line-height:1.7;white-space:pre-wrap}
.detail-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:8px}
.detail-top h2{font-size:18px;font-weight:500;flex:1}
.btn-danger{color:#A32D2D;border-color:#F09595}
.btn-danger:hover{background:#FCEBEB}
.pub-toggle{display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:#1a1a1a}
.ing-table{width:100%;border-collapse:collapse;font-size:13px}
.ing-table th{font-size:11px;color:#555;font-weight:700;padding:4px 6px;border-bottom:2px solid #ddd;text-align:left}
.ing-table td{padding:3px 4px;vertical-align:middle}
.ing-table td input{height:30px;padding:0 6px;border:1px solid #ddd;border-radius:6px;font-size:13px;background:#fff;color:#1a1a1a;width:100%;outline:none}
.ing-table td input:focus{border-color:#D4537E}
.col-name{width:35%}.col-amt{width:23%}.col-note{width:auto}.col-del{width:24px}.col-move{width:28px}
.btn-del-row{background:none;border:none;cursor:pointer;color:#ccc;font-size:14px;line-height:1;padding:0 2px}
.btn-del-row:hover{color:#E24B4A}
.btn-move-row{background:none;border:none;cursor:pointer;color:#ccc;font-size:11px;line-height:1.1;padding:0;display:block;width:14px;text-align:center}
.btn-move-row:hover{color:#888}
.photo-cover-label{display:flex;align-items:center;gap:3px;font-size:11px;color:#888;white-space:nowrap;cursor:pointer}
.photo-cover-label input{width:auto;height:auto;cursor:pointer}
.btn-add-row{height:26px;padding:0 10px;font-size:12px;border:1px dashed #D4537E;border-radius:6px;background:#fff;color:#D4537E;cursor:pointer;margin-top:5px}
.btn-add-row:hover{background:#FBEAF0}
.btn-add-part{height:26px;padding:0 10px;font-size:12px;border:1px dashed #aaa;border-radius:6px;background:#fff;color:#888;cursor:pointer;margin-top:5px;margin-left:6px}
.btn-add-part:hover{background:#f5f5f5}
.ing-part{margin-bottom:10px;border:1px solid #f0e0eb;border-radius:8px;padding:8px 10px;transition:opacity .15s}
.ing-part.drag-over{border-color:#D4537E;background:#fff8fb}
.ing-part-header{display:flex;align-items:center;gap:6px;margin-bottom:6px}
.drag-handle{cursor:grab;color:#ccc;font-size:15px;flex-shrink:0;line-height:1;user-select:none;padding:0 2px}
.drag-handle:hover{color:#aaa}
.drag-handle:active{cursor:grabbing}
.ing-part-name{height:26px;padding:0 6px;border:1px solid #e8d0dc;border-radius:6px;background:#fff8fb;font-size:13px;font-weight:500;color:#993556;outline:none;flex:1;max-width:200px}
.ing-part-name:focus{border-color:#D4537E}
.ing-part-label-wrap{display:inline-flex;align-items:center;gap:4px;background:#f0e0eb;padding:2px 8px 2px 6px;border-radius:6px}
.ing-part-name::placeholder{color:#ccc;font-weight:400}
.btn-del-part{background:none;border:none;cursor:pointer;color:#ccc;font-size:13px;line-height:1;padding:2px 4px;margin-left:auto;border-radius:4px}
.btn-del-part:hover{color:#E24B4A;background:#fff0f0}
.photo-list{display:flex;flex-direction:column;gap:8px;margin-bottom:8px}
.photo-item{display:flex;align-items:center;gap:8px;border:1px solid #eee;border-radius:8px;padding:6px 8px;background:#fff}
.photo-thumb{width:52px;height:40px;object-fit:cover;border-radius:5px;flex-shrink:0}
.photo-title-input{flex:1;height:28px;padding:0 8px;border:1px solid #ddd;border-radius:6px;font-size:13px;background:#fff;color:#1a1a1a;outline:none}
.photo-title-input:focus{border-color:#D4537E}
.btn-del-photo{background:none;border:none;cursor:pointer;color:#ccc;font-size:14px;padding:0 2px;line-height:1}
.btn-del-photo:hover{color:#E24B4A}
.btn-add-photo{height:28px;padding:0 12px;font-size:12px;border:1px dashed #aaa;border-radius:6px;background:#fff;color:#888;cursor:pointer}
.btn-add-photo:hover{background:#f5f5f5}
.photo-gallery{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:8px}
.photo-gallery-item{display:flex;flex-direction:column;align-items:center;gap:3px}
.photo-gallery-item img{width:90px;height:70px;border-radius:6px;display:block;object-fit:cover;cursor:pointer;border:1px solid #eee;transition:opacity .15s}
.photo-gallery-item img:hover{opacity:0.8}
.photo-gallery-caption{font-size:11px;color:#888;text-align:center;max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:500;align-items:center;justify-content:center;flex-direction:column;gap:10px;padding:1rem}
.lightbox.open{display:flex}
.lightbox img{max-width:100%;max-height:80vh;border-radius:8px;object-fit:contain}
.lightbox-caption{color:#fff;font-size:13px;text-align:center}
.lightbox-close{position:absolute;top:14px;right:18px;background:none;border:none;color:#fff;font-size:24px;cursor:pointer;line-height:1}

.crown-btn {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 18px;
  padding: 0;
  line-height: 1;
  color: #ccc;
  transition: color 0.2s;
}
.crown-btn.on {
  color: #FFD700;
  text-shadow: 0 0 5px rgba(255, 215, 0, 0.3);
}

.related-card {
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  padding: 6px 10px;
  background: #fff;
  transition: border-color .15s;
}
.related-card:hover { border-color: #aaa; }
.related-card-thumb { width: 36px; height: 36px; border-radius: 5px; object-fit: cover; flex-shrink: 0; }
.related-card-placeholder { width: 36px; height: 36px; border-radius: 5px; background: #FBEAF0; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.related-card-name { font-size: 13px; color: #1a1a1a; }

.ing-link { color: #185FA5; cursor: pointer; text-decoration: underline; }
.ing-link:hover { color: #0d3d73; }
.ing-name-linked { color: #185FA5 !important; }
